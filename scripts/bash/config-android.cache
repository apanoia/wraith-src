# Autoconf cache values for cross-compiling bash to Android/bionic.
# These answer the runtime feature probes that ./configure cannot run
# when building for a different host. Values reflect bionic (API 29+).
bash_cv_getcwd_malloc=yes
bash_cv_job_control_missing=present
bash_cv_sys_named_pipes=present
bash_cv_func_sigsetjmp=present
bash_cv_unusable_rtsigs=no
bash_cv_wcwidth_broken=no
bash_cv_func_strcoll_broken=no
bash_cv_dup2_broken=no
bash_cv_pgrp_pipe=no
bash_cv_type_rlimit=rlim_t
bash_cv_fnmatch_equiv_fallback=false
bash_cv_signal_vintage=posix
bash_cv_must_reinstall_sighandlers=no
bash_cv_func_ctype_nonascii=yes
bash_cv_ulimit_maxfds=yes
bash_cv_getenv_redef=yes
bash_cv_printf_a_format=yes
ac_cv_func_mkfifo=yes
ac_cv_func_working_mktime=yes
ac_cv_func_strtold=yes
ac_cv_func_strtoimax=yes
ac_cv_func_strtoumax=yes
